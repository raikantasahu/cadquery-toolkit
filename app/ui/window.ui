<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk+" version="3.20"/>

  <object class="GtkMenuBar" id="menubar">
    <!-- Model menu -->
    <child>
      <object class="GtkMenuItem" id="model_menu_item">
        <property name="label">Model</property>
        <child type="submenu">
          <object class="GtkMenu" id="model_menu">
            <child>
              <object class="GtkMenuItem" id="menu_view">
                <property name="label">View</property>
                <property name="sensitive">False</property>
                <signal name="activate" handler="_on_menu_view"/>
              </object>
            </child>
            <child>
              <object class="GtkMenuItem" id="menu_export">
                <property name="label">Export</property>
                <property name="sensitive">False</property>
                <signal name="activate" handler="_on_menu_export"/>
              </object>
            </child>
            <child>
              <object class="GtkSeparatorMenuItem"/>
            </child>
            <child>
              <object class="GtkMenuItem" id="menu_pick_faces">
                <property name="label">Pick Faces…</property>
                <property name="sensitive">False</property>
                <signal name="activate" handler="_on_menu_pick_faces"/>
              </object>
            </child>
            <child>
              <object class="GtkMenuItem" id="menu_edit_face_selection">
                <property name="label">Edit Face Selection…</property>
                <property name="sensitive">False</property>
                <signal name="activate" handler="_on_menu_edit_face_selection"/>
              </object>
            </child>
            <child>
              <object class="GtkMenuItem" id="menu_pick_edges">
                <property name="label">Pick Edges…</property>
                <property name="sensitive">False</property>
                <signal name="activate" handler="_on_menu_pick_edges"/>
              </object>
            </child>
            <child>
              <object class="GtkMenuItem" id="menu_edit_edge_selection">
                <property name="label">Edit Edge Selection…</property>
                <property name="sensitive">False</property>
                <signal name="activate" handler="_on_menu_edit_edge_selection"/>
              </object>
            </child>
            <child>
              <object class="GtkMenuItem" id="menu_pick_vertices">
                <property name="label">Pick Vertices…</property>
                <property name="sensitive">False</property>
                <signal name="activate" handler="_on_menu_pick_vertices"/>
              </object>
            </child>
            <child>
              <object class="GtkMenuItem" id="menu_edit_vertex_selection">
                <property name="label">Edit Vertex Selection…</property>
                <property name="sensitive">False</property>
                <signal name="activate" handler="_on_menu_edit_vertex_selection"/>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>

    <!-- Mesh menu -->
    <child>
      <object class="GtkMenuItem" id="mesh_menu_item">
        <property name="label">Mesh</property>
        <child type="submenu">
          <object class="GtkMenu" id="mesh_menu">
            <child>
              <object class="GtkMenuItem" id="menu_create_mesh">
                <property name="label">Create Mesh</property>
                <property name="sensitive">False</property>
                <signal name="activate" handler="_on_menu_create_mesh"/>
              </object>
            </child>
            <child>
              <object class="GtkMenuItem" id="menu_view_mesh">
                <property name="label">View Mesh</property>
                <property name="sensitive">False</property>
                <signal name="activate" handler="_on_menu_view_mesh"/>
              </object>
            </child>
            <child>
              <object class="GtkMenuItem" id="menu_save_mesh">
                <property name="label">Save Mesh</property>
                <property name="sensitive">False</property>
                <signal name="activate" handler="_on_menu_save_mesh"/>
              </object>
            </child>
            <child>
              <object class="GtkMenuItem" id="menu_show_stats">
                <property name="label">Show Stats</property>
                <property name="sensitive">False</property>
                <signal name="activate" handler="_on_menu_show_stats"/>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
  </object>
</interface>
